<%- include('partials/header') %>

<h1 class="text-3xl font-bold text-gray-800 mb-6">Anlaesse</h1>

<div class="bg-white rounded-lg shadow p-6 mb-6">
  <ul class="space-y-2">
    <% occasions.forEach(o => { %>
      <li class="flex items-center gap-3">
        <span class="font-medium"><%= o.name %></span>
        <% if (o.is_fixed) { %>
          <span class="text-xs bg-blue-100 text-blue-700 px-2 py-1 rounded">Fest</span>
        <% } else { %>
          <span class="text-xs bg-gray-100 text-gray-600 px-2 py-1 rounded">Benutzerdefiniert</span>
          <form action="/occasions/<%= o.id %>/delete" method="POST" class="inline">
            <button type="submit" class="text-red-500 text-sm">Loeschen</button>
          </form>
        <% } %>
      </li>
    <% }) %>
  </ul>
</div>

<div class="bg-white rounded-lg shadow p-6">
  <h2 class="text-lg font-semibold text-gray-700 mb-4">Neuen Anlass erstellen</h2>
  <form action="/occasions" method="POST" class="flex gap-4">
    <input type="text" name="name" required placeholder="z.B. Hochzeitstag, Ostern..."
           class="flex-1 border rounded px-3 py-2">
    <button type="submit" class="bg-pink-500 text-white px-4 py-2 rounded">Anlegen</button>
  </form>
</div>

<%- include('partials/footer') %>
