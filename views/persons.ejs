<%- include('partials/header') %>

<h1 class="text-3xl font-bold text-gray-800 mb-6">Personen</h1>

<div class="bg-white rounded-lg shadow p-6 mb-6">
  <% if (persons.length === 0) { %>
    <p class="text-gray-500">Noch keine Personen angelegt.</p>
  <% } else { %>
    <ul class="space-y-2">
      <% persons.forEach(p => { %>
        <li><a href="/persons/<%= p.id %>" class="text-pink-600 hover:underline"><%= p.name %></a></li>
      <% }) %>
    </ul>
  <% } %>
</div>

<div class="bg-white rounded-lg shadow p-6">
  <h2 class="text-lg font-semibold text-gray-700 mb-4">Neue Person anlegen</h2>
  <form action="/persons" method="POST" class="flex gap-4">
    <input type="text" name="name" required placeholder="Name"
           class="flex-1 border rounded px-3 py-2">
    <input type="date" name="birthday" class="border rounded px-3 py-2">
    <input type="text" name="notes" placeholder="Notizen" class="border rounded px-3 py-2">
    <button type="submit" class="bg-pink-500 text-white px-4 py-2 rounded">Anlegen</button>
  </form>
</div>

<%- include('partials/footer') %>
